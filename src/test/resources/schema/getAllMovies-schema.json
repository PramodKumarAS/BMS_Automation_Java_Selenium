{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "movies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "movieName": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "duration": {
            "type": "integer"
          },
          "genre": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "releaseDate": {
            "type": "string",
            "format": "date-time"
          },
          "poster": {
            "type": "string"
          },
          "__v": {
            "type": "integer"
          }
        },
        "required": [
          "_id",
          "movieName",
          "description",
          "duration",
          "genre",
          "language",
          "releaseDate"
        ]
      }
    }
  },
  "required": ["success", "message", "movies"]
}