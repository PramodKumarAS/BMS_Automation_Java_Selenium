{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "shows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "time": {
            "type": "string",
            "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
          },

          "movie": {
            "type": "object",
            "properties": {
              "_id": { "type": "string" },
              "movieName": { "type": "string" },
              "description": { "type": "string" },
              "duration": { "type": "integer" },
              "genre": { "type": "string" },
              "language": { "type": "string" },
              "releaseDate": {
                "type": "string",
                "format": "date-time"
              },
              "poster": { "type": "string" },
              "__v": { "type": "integer" }
            },
            "required": ["_id", "movieName", "duration"]
          },

          "ticketPrice": {
            "type": "number",
            "minimum": 0
          },
          "totalSeats": {
            "type": "integer",
            "minimum": 1
          },

          "theatre": {
            "type": "string"
          },

          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "__v": { "type": "integer" },

          "bookedSeats": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": [
          "_id",
          "name",
          "date",
          "time",
          "movie",
          "ticketPrice",
          "totalSeats"
        ]
      }
    }
  },
  "required": ["success", "message", "shows"]
}